# Application database. Use a direct connection for migrations and a pooler-compatible
# connection for serverless runtime traffic when your deployment requires it.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/conectapelu2

# Safe to expose in browser bundles. Obtain these from the Supabase project settings
# or from `supabase status` when running Supabase locally.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key

# Server-only. Use a current Supabase secret key (`sb_secret_...`) for privileged
# Auth operations. Never prefix this value with NEXT_PUBLIC_ or expose it to browser code.
SUPABASE_SECRET_KEY=

# Used only by `pnpm db:bootstrap`. The mailbox must support plus addressing so the
# command can derive +admin, +org, and +user role accounts.
BOOTSTRAP_OWNER_EMAIL=owner@example.com
BOOTSTRAP_ORGANIZATION_NAME=Refugio Esperanza
BOOTSTRAP_ORGANIZATION_SLUG=refugio-esperanza
